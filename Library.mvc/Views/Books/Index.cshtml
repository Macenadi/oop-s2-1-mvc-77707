@model Library.MVC.ViewModels.BookFilterViewModel

@{
    ViewData["Title"] = "Books";
}

<div class="section-header">
    <h1 class="page-title">Books</h1>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</div>

<div class="card card-soft mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="searchString" value="@Model.SearchString" class="form-control" placeholder="Search by title or author" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Category</label>
                <select name="category" class="form-select" asp-items="Model.Categories">
                    <option value="">All</option>
                </select>
            </div>

            <div class="col-md-3">
                <label class="form-label">Availability</label>
                <select name="availability" class="form-select">
                    <option value="">All</option>
                    <option value="Available" selected="@(Model.Availability == "Available")">Available</option>
                    <option value="OnLoan" selected="@(Model.Availability == "OnLoan")">On Loan</option>
                </select>
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Books != null && Model.Books.Any())
{
    <div class="card card-soft">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="px-3">Title</th>
                        <th>Author</th>
                        <th>ISBN</th>
                        <th>Category</th>
                        <th>Availability</th>
                        <th class="text-end px-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Books)
                    {
                        <tr>
                            <td class="px-3">@item.Title</td>
                            <td>@item.Author</td>
                            <td>@item.Isbn</td>
                            <td>@item.Category</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">On Loan</span>
                                }
                            </td>
                            <td class="text-end px-3">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No books found.</div>
}