@model Library.MVC.ViewModels.BookFilterViewModel

@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<form asp-action="Index" method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <label class="form-label">Search</label>
        <input type="text" name="searchString" value="@Model.SearchString" class="form-control" placeholder="Search by title or author" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Category</label>
        <select name="category" class="form-select" asp-items="Model.Categories">
            <option value="">All</option>
        </select>
    </div>

    <div class="col-md-3">
        <label class="form-label">Availability</label>
        <select name="availability" class="form-select">
            <option value="">All</option>
            <option value="Available" selected="@(Model.Availability == "Available")">Available</option>
            <option value="OnLoan" selected="@(Model.Availability == "OnLoan")">On Loan</option>
        </select>
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary me-2">Filter</button>
        <a asp-action="Index" class="btn btn-secondary">Reset</a>
    </div>
</form>

@if (Model.Books != null && Model.Books.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>ISBN</th>
                <th>Category</th>
                <th>Availability</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Books)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Author</td>
                    <td>@item.Isbn</td>
                    <td>@item.Category</td>
                    <td>@(item.IsAvailable ? "Available" : "On Loan")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No books found.</p>
}