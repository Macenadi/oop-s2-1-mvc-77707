@{
    ViewData["Title"] = "Home";
}

<div class="hero-box text-center mb-4">
    <h1>Community Library Desk</h1>
    <p>Manage books, members, loans, and roles in one simple library system.</p>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="mt-4">
            <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-lg me-2">View Books</a>
            <a asp-controller="Loans" asp-action="Index" class="btn btn-outline-light btn-lg">View Loans</a>
        </div>
    }
    else
    {
        <div class="mt-4">
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-light btn-lg me-2">Login</a>
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-light btn-lg">Register</a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card card-soft h-100">
            <div class="card-body">
                <h4 class="card-title">Books</h4>
                <p class="card-text">Search, filter, create, edit, and manage the library collection.</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-soft h-100">
            <div class="card-body">
                <h4 class="card-title">Members</h4>
                <p class="card-text">Keep track of library members and their contact details.</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-soft h-100">
            <div class="card-body">
                <h4 class="card-title">Loans</h4>
                <p class="card-text">Create loans, return books, and monitor active or overdue items.</p>
            </div>
        </div>
    </div>
</div>