@model IEnumerable<Library.domain.Models.Loan>

@{
    ViewData["Title"] = "Loans";
}

<div class="section-header">
    <h1 class="page-title">Loans</h1>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</div>

@if (Model != null && Model.Any())
{
    <div class="card card-soft">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="px-3">Book</th>
                        <th>Member</th>
                        <th>Loan Date</th>
                        <th>Due Date</th>
                        <th>Returned Date</th>
                        <th>Status</th>
                        <th class="text-end px-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var isOverdue = item.ReturnedDate == null && item.DueDate < DateTime.Now;
                        var isReturned = item.ReturnedDate != null;

                        <tr>
                            <td class="px-3">@item.Book?.Title</td>
                            <td>@item.Member?.FullName</td>
                            <td>@item.LoanDate.ToString("dd/MM/yyyy")</td>
                            <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                            <td>@(item.ReturnedDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>
                                @if (isReturned)
                                {
                                    <span class="badge bg-success">Returned</span>
                                }
                                else if (isOverdue)
                                {
                                    <span class="badge bg-danger">Overdue</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Active</span>
                                }
                            </td>
                            <td class="text-end px-3">
                                @if (!isReturned)
                                {
                                    <form asp-action="Return" asp-route-id="@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success">Return</button>
                                    </form>
                                }
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No loans found.</div>
}
