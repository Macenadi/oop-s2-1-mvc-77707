@model IEnumerable<Library.domain.Models.Member>

@{
    ViewData["Title"] = "Members";
}

<div class="section-header">
    <h1 class="page-title">Members</h1>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</div>

@if (Model != null && Model.Any())
{
    <div class="card card-soft">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="px-3">Full Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-end px-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-3">@item.FullName</td>
                            <td>@item.Email</td>
                            <td>@item.Phone</td>
                            <td class="text-end px-3">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">No members found.</div>
}
